# AI-KungFU SII Stack — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=sii
POSTGRES_USER=sii
POSTGRES_PASSWORD=changeme-strong-password-here

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=changeme-32-character-key-here!!!

# ── LiteLLM ──────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-sii-changeme
DATABASE_URL=postgresql://sii:changeme@postgres:5432/sii

# ── Western Stack ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ── Eastern Stack (cheap bulk processing) ────────────────────────────────────
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=

# ── MCP Servers (Daraja sandbox defaults) ────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# ── WhatsApp Business API ────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Delivery ─────────────────────────────────────────────────────────────────
AFRICA_TALKING_USERNAME=sandbox
AFRICA_TALKING_API_KEY=

# Note: Sovereign stack (Ollama) needs no API keys — runs locally
